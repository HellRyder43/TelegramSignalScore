# ─── Telegram ───────────────────────────────────────────────────────────────
# From https://my.telegram.org → API development tools
TG_API_ID=
TG_API_HASH=
# Filename for the Telethon session file (stored as <name>.session — gitignored)
TG_SESSION_NAME=xau_signal_bot
# Optional: separate session file for the backfill script (defaults to
# <TG_SESSION_NAME>_backfill). Telethon can't share one session across two running
# processes, so this lets backfill run while the live listener is up.
# TG_BACKFILL_SESSION_NAME=xau_signal_bot_backfill
# Comma-separated channel IDs to monitor. Run list_channels.py to find them.
# Example: TRACKED_CHANNEL_IDS=-1001234567890,-1009876543210
TRACKED_CHANNEL_IDS=

# ─── MetaTrader 5 ────────────────────────────────────────────────────────────
# Exact symbol name as shown in MT5 Market Watch (e.g. XAUUSD.r)
MT5_SYMBOL=XAUUSD
# Optional — only needed if you want programmatic MT5 login (otherwise MT5 must already be open)
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=

# ─── Discord ─────────────────────────────────────────────────────────────────
# Bot token from https://discord.com/developers/applications → Bot → Token
DISCORD_BOT_TOKEN=
# ID of the channel where alerts should be posted (enable Developer Mode → right-click channel → Copy ID)
DISCORD_CHANNEL_ID=

# ─── Supabase ────────────────────────────────────────────────────────────────
# From https://supabase.com → Project Settings → API
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Anthropic (image/vision parsing — Phase 7, optional for now) ───────────
ANTHROPIC_API_KEY=

# ─── App ─────────────────────────────────────────────────────────────────────
# How often (seconds) the verification scheduler re-checks unresolved signals
VERIFY_INTERVAL_SECS=300

# Environment: development | production
APP_ENV=development
